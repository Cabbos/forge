{
  "name": "forge-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:desktop": "npm --prefix apps/desktop run tauri dev",
    "dev:desktop:web": "npm --prefix apps/desktop run dev",
    "dev:website": "npm --prefix apps/website run dev",
    "build:desktop": "npm --prefix apps/desktop run build",
    "build:website": "npm --prefix apps/website run build",
    "check:ci": "node --test scripts/ci-workflow.test.mjs",
    "release:candidate": "node scripts/build-release-candidate.mjs",
    "release:validate": "node scripts/validate-release-manifest.mjs --release-profile release/release-gates.v1.json",
    "forge:feishu:dry-run": "node scripts/sync-forge-feishu.mjs --commit HEAD --dry-run",
    "forge:feishu:setup": "node scripts/sync-forge-feishu.mjs --setup-feishu",
    "forge:feishu:sync": "node scripts/sync-forge-feishu.mjs --commit HEAD",
    "test:eval": "node scripts/eval-doctor-precheck.mjs && cd apps/eval-runner && uv run pytest",
    "eval:forge:mock": "npm --prefix apps/desktop run eval:forge:mock --",
    "eval:forge:smoke": "npm --prefix apps/desktop run eval:forge:smoke --",
    "eval:forge:smoke:real": "npm --prefix apps/desktop run eval:forge:smoke:real --",
    "eval:forge:smoke:dry-run": "npm --prefix apps/desktop run eval:forge:smoke:dry-run --",
    "eval:continuity": "npm --prefix apps/desktop run eval:continuity --",
    "eval:report": "npm --prefix apps/desktop run eval:report --",
    "eval:report:latest": "npm --prefix apps/desktop run eval:report:latest --"
  }
}
