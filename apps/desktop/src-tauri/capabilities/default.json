{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri/capability.schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "dialog:allow-open",
    "core:event:allow-listen",
    "core:event:allow-unlisten"
  ]
}
