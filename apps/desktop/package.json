{
  "name": "forge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare": "node scripts/install-git-hooks.mjs",
    "prebuild": "npm run check:conversation-style",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "check:conversation-style": "node scripts/check-conversation-style.mjs",
    "check:deterministic-signals": "node --test scripts/desktop-deterministic-signals.test.mjs",
    "check:security-config": "node --test scripts/desktop-security-config.test.mjs",
    "check:protocol": "node scripts/check-protocol-sync.mjs",
    "check:desktop-boundary": "node --test scripts/desktop-product-boundary.test.mjs",
    "check:backend": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings && cargo test --manifest-path src-tauri/Cargo.toml",
    "check:precommit": "node scripts/pre-commit-check.mjs",
    "check:precommit:test": "node --test scripts/pre-commit-check.test.mjs",
    "check:frontend-architecture": "node --test scripts/react-query-pilot.test.mjs scripts/react-query-migration.test.mjs scripts/desktop-product-boundary.test.mjs",
    "eval:forge": "node scripts/run-forge-backtest.mjs",
    "eval:forge:dry-run": "node scripts/run-forge-backtest.mjs --dry-run",
    "eval:forge:mock": "node scripts/run-forge-backtest.mjs --provider mock",
    "eval:forge:smoke": "node scripts/run-forge-backtest.mjs --case forge-session-capitalize",
    "eval:forge:smoke:real": "node scripts/run-forge-backtest.mjs --case forge-session-capitalize --require-key --timeout 120 --max-model-rounds 20",
    "eval:forge:smoke:dry-run": "node scripts/run-forge-backtest.mjs --case forge-session-capitalize --dry-run",
    "eval:forge:smoke:worktree:real": "node scripts/smoke-worktree-worker.mjs --require-key --timeout 120 --max-model-rounds 20",
    "eval:forge:smoke:worktree:dry-run": "node scripts/smoke-worktree-worker.mjs --dry-run",
    "smoke:gateway:webhook": "node scripts/smoke-gateway-webhook.mjs",
    "smoke:gateway:restart": "node scripts/smoke-gateway-restart.mjs",
    "eval:continuity": "node scripts/run-forge-backtest.mjs --suite continuity",
    "eval:continuity:dry-run": "node scripts/run-forge-backtest.mjs --suite continuity --dry-run",
    "eval:continuity:smoke": "node scripts/run-forge-backtest.mjs --suite continuity --case continuity-pipeline-normalize-input",
    "eval:forge:test": "node --test scripts/run-forge-backtest.test.mjs scripts/eval-report.test.mjs scripts/smoke-worktree-worker.test.mjs scripts/smoke-gateway-webhook.test.mjs scripts/smoke-gateway-restart.test.mjs",
    "eval:report": "node scripts/eval-report.mjs",
    "eval:report:latest": "node scripts/eval-report.mjs --latest",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@gsap/react": "^2.1.2",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-virtual": "^3.0.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "gsap": "^3.15.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.0",
    "react-resizable-panels": "^4.10.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.6.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.0",
    "vite": "^8.1.0"
  }
}
