{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.example/release/release-manifest.schema.json",
  "type": "object",
  "required": ["schema_version", "release_state", "version", "commit_sha", "source_branch", "lockfiles", "profile_id", "gates", "eval_evidence", "artifacts", "signing", "notarization", "installation_smoke", "website", "residual_risks", "generated_at"],
  "properties": {
    "schema_version": { "const": 1 },
    "release_state": { "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "version": { "type": "string", "minLength": 1 },
    "commit_sha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "source_branch": { "const": "main" },
    "lockfiles": { "type": "array", "minItems": 1 },
    "profile_id": { "type": "string", "minLength": 1 },
    "gates": { "type": "array" },
    "eval_evidence": { "type": "array" },
    "artifacts": { "type": "array" },
    "signing": { "type": "object" },
    "notarization": { "type": "object" },
    "installation_smoke": { "type": "object" },
    "website": { "type": "object" },
    "residual_risks": { "type": "array" },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
