{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.example/release/release-manifest.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "release_state",
    "version",
    "commit_sha",
    "source_branch",
    "generated_at",
    "profile_id",
    "profile_sha256",
    "lockfiles",
    "selected_gates",
    "gate_summary",
    "gates",
    "input_bindings",
    "eval_evidence",
    "artifacts",
    "signing",
    "notarization",
    "installation_smoke",
    "website",
    "previous_release",
    "gitnexus",
    "residual_risks"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "release_state": { "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "version": { "type": "string", "pattern": "^desktop-v[0-9]+\\.[0-9]+\\.[0-9]+-beta\\.[0-9]+$" },
    "commit_sha": { "$ref": "#/$defs/sha40" },
    "source_branch": { "const": "main" },
    "generated_at": { "type": "string", "format": "date-time" },
    "profile_id": { "type": "string", "minLength": 1 },
    "profile_sha256": { "$ref": "#/$defs/sha256" },
    "lockfiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pathDigest" }
    },
    "selected_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/selectedGate" }
    },
    "gate_summary": {
      "type": "object",
      "required": ["selected_count", "executed_count", "failed_execution_count", "failed_condition_count", "unknown_condition_count"],
      "properties": {
        "selected_count": { "type": "integer", "minimum": 0 },
        "executed_count": { "type": "integer", "minimum": 0 },
        "failed_execution_count": { "type": "integer", "minimum": 0 },
        "failed_condition_count": { "type": "integer", "minimum": 0 },
        "unknown_condition_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/gateResult" }
    },
    "input_bindings": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["role", "path", "sha256", "bound_commit_sha"],
        "properties": {
          "role": {
            "enum": [
              "acceptance_results",
              "desktop_safety",
              "eval_trustworthiness",
              "gitnexus",
              "representative_mock",
              "representative_real_forge"
            ]
          },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" },
          "bound_commit_sha": { "$ref": "#/$defs/sha40" },
          "producer_commit": { "$ref": "#/$defs/sha40" }
        },
        "additionalProperties": false
      }
    },
    "eval_evidence": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "path", "sha256", "trust_result"],
        "properties": {
          "role": { "enum": ["representative_mock", "representative_real_forge"] },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" },
          "trust_result": { "enum": ["trusted", "untrusted", "unknown"] }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/pathDigest" }
    },
    "signing": { "$ref": "#/$defs/statusObject" },
    "notarization": { "$ref": "#/$defs/statusObject" },
    "installation_smoke": { "$ref": "#/$defs/statusObject" },
    "website": { "$ref": "#/$defs/statusObject" },
    "previous_release": { "type": ["string", "null"] },
    "gitnexus": {
      "type": "object",
      "required": ["mode", "current_commit", "indexed_commit", "impact_risk", "evidence_path", "evidence_sha256"],
      "properties": {
        "mode": { "enum": ["indexed", "fallback"] },
        "current_commit": { "$ref": "#/$defs/sha40" },
        "indexed_commit": { "$ref": "#/$defs/sha40" },
        "impact_risk": { "type": "string", "minLength": 1 },
        "evidence_path": { "type": "string", "minLength": 1 },
        "evidence_sha256": { "$ref": "#/$defs/sha256" },
        "refresh_error": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "residual_risks": { "type": "array" }
  },
  "additionalProperties": false,
  "$defs": {
    "sha40": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "pathDigest": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "selectedGate": {
      "type": "object",
      "required": ["id", "label", "command", "required_for", "manual_allowed"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "required_for": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["R1", "R2", "R3", "R4"] }
        },
        "manual_allowed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "gateResult": {
      "type": "object",
      "required": [
        "id",
        "label",
        "command",
        "required_for",
        "manual_allowed",
        "execution_status",
        "condition_status",
        "status",
        "exit_code",
        "evidence_sha256"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "required_for": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["R1", "R2", "R3", "R4"] }
        },
        "manual_allowed": { "type": "boolean" },
        "execution_status": { "enum": ["not_started", "running", "completed", "execution_failed"] },
        "condition_status": { "enum": ["passed", "failed", "manual", "unknown"] },
        "status": { "enum": ["passed", "failed", "manual", "unknown"] },
        "exit_code": { "type": ["integer", "null"] },
        "evidence_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "statusObject": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  }
}
