{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.example/release/release-gate-profile.schema.json",
  "type": "object",
  "required": ["id", "version", "gates"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "const": 1 },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "required_for", "label", "domain", "tier", "manual_allowed", "command", "ci_default"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "required_for": { "type": "array", "items": { "enum": ["R1", "R2", "R3", "R4"] }, "minItems": 1 },
          "label": { "type": "string", "minLength": 1 },
          "domain": { "type": "string", "minLength": 1 },
          "tier": { "type": "string", "minLength": 1 },
          "manual_allowed": { "type": "boolean" },
          "command": { "type": "string", "minLength": 1 },
          "evidence_schema": { "type": "string" },
          "ci_default": { "type": "boolean" }
        }
      }
    }
  },
  "additionalProperties": false
}
